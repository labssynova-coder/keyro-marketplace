# ─── Server ───
PORT=3000

# ─── Database ───
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=keyro_db

# ─── JWT Authentication ───
# Generate strong random strings for production: `openssl rand -base64 64`
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Key Delivery Encryption ───
# Used to encrypt product keys at rest (AES-256-GCM)
# Defaults to JWT_SECRET if not set
DELIVERY_SECRET_KEY=change-me-to-a-stable-64-char-delivery-encryption-key

# ─── Frontend ───
FRONTEND_URL=http://localhost:3000

# ─── Payment ───
PAYMENT_PROVIDER=custom
PAYMENT_CURRENCY=eur
PAYMENT_CONFIRM_SECRET=change-me-to-a-random-server-to-server-secret

# ─── Rate Limiting ───
API_RATE_LIMIT_MAX=2000
AUTH_RATE_LIMIT_MAX=20

# ─── Uploads ───
UPLOAD_DIR=public/img/products
MAX_FILE_SIZE=5242880